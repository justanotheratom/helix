# Helix environment. Copy to .env (gitignored) and fill in.

# ---- LLM provider secrets propagated to the worker subprocess ----
OPENAI_API_KEY=
GEMINI_API_KEY=
ANTHROPIC_API_KEY=
OPENROUTER_API_KEY=
CEREBRAS_API_KEY=
GROQ_API_KEY=
GROK_API_KEY=
TOGETHERAI_API_KEY=
HF_TOKEN=
LM_STUDIO_API_KEY=

# ---- Vertex AI: tuned-Gemini endpoints in the us/eu MULTI-region ----
# litellm can't address the multi-region, so the consumer's program uses a
# google-genai shim (model string `vertex_genai/<endpoint-id>`). These flow
# into the worker job env. The SA key MUST be COMPACT one-line JSON (the .env
# is line-based) and have aiplatform.endpoints.predict on the target project.
GOOGLE_APPLICATION_CREDENTIALS_JSON=
VERTEX_PROJECT=
VERTEX_LOCATION=us

# ---- Langfuse: internal sample rate; project keys are seeded by INIT vars below ----
LANGFUSE_SAMPLE_RATE=1.0

# ---- Helix-internal credentials (don't change unless you know why) ----
HELIX_POSTGRES_PASSWORD=helix-local-dev
HELIX_MINIO_ROOT_USER=helix
HELIX_MINIO_ROOT_PASSWORD=helix-local-dev-minio
HELIX_REDIS_PASSWORD=helix-local-dev-redis

# ---- Langfuse stack ----
LANGFUSE_POSTGRES_PASSWORD=langfuse-local-dev
LANGFUSE_CLICKHOUSE_PASSWORD=clickhouse-local-dev
LANGFUSE_MINIO_ROOT_USER=langfuse
LANGFUSE_MINIO_ROOT_PASSWORD=langfuse-local-dev-minio
LANGFUSE_REDIS_PASSWORD=langfuse-local-dev-redis
# Generated 32-byte hex strings; rotate by running `openssl rand -hex 32`
LANGFUSE_SALT=53aceb7f9ef6c4a9e97ed28032a68338a3b6c5d2e1f4a7b8c9d0e1f2a3b4c5d6
LANGFUSE_ENCRYPTION_KEY=f5886d764f9ae75419be3efcfe2c1eb2edb9e715a0bcb62ad77caf6c7bc05bf1
LANGFUSE_NEXTAUTH_SECRET=2cbd591a422550d1fdf456cfe75af23b3c51e5377e2d5cda1bf27c039b3b299e

# ---- Langfuse seed user (used by Helix auto-SSO; user never types these) ----
# LANGFUSE_INIT_PROJECT_ID is normally overridden by `helix up` from
# [stack].langfuse_project_id in .helix.toml; this is just a generic default.
LANGFUSE_INIT_ORG_ID=helix-local
LANGFUSE_INIT_ORG_NAME=helix
LANGFUSE_INIT_PROJECT_ID=helix
LANGFUSE_INIT_PROJECT_NAME=helix
LANGFUSE_INIT_PROJECT_PUBLIC_KEY=pk-lf-helix-localdev
LANGFUSE_INIT_PROJECT_SECRET_KEY=sk-lf-helix-localdev
LANGFUSE_INIT_USER_EMAIL=owner@fungee.llc
LANGFUSE_INIT_USER_NAME=owner
LANGFUSE_INIT_USER_PASSWORD=helix-local-dev-langfuse

# ---- Worker scaling ----
HELIX_WORKER_REPLICAS=1

# ---- Public URL (team / Cloudflare tunnel deploy) ----
# Set when using docker-compose.cloudflare.yml so API job links are correct.
# HELIX_PUBLIC_BASE_URL=https://helix.buildwithhelix.xyz

# ---- Cloudflare Tunnel (docker-compose.cloudflare.yml) ----
# CF_TUNNEL_TOKEN=
